{
  "name": "zombie-survival",
  "version": "1.0.2",
  "description": "Zombie Survival — desktop build",
  "main": "main.js",
  "author": "Omar",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "publish": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.omar.zombiesurvival",
    "productName": "Zombie Survival",
    "files": [
      "main.js",
      "index.html",
      "vendor/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "khatibapp",
        "repo": "zombie-survival"
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
